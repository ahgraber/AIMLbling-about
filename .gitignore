# -------------------------------------------------------
# Dot-directories: ignore all, allowlist what we track
# -------------------------------------------------------
.*/
!.claude/
!.github/
!.specs/
!.renovate/

# -------------------------------------------------------
# OS
# -------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Secrets & environment
# -------------------------------------------------------
.env
.envrc
*.pem
*.key
*.pgp
.decrypted~*

# -------------------------------------------------------
# AI tooling (local/personal files only)
# -------------------------------------------------------
CLAUDE.md
CLAUDE.local.md
.claude/settings.local.json
docs/superpowers/

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.coverage
.coverage.*

# -------------------------------------------------------
# Dependencies & build output
# -------------------------------------------------------
node_modules/
build/
dist/
site/
**/cache/

# -------------------------------------------------------
# Temp, logs, & working files
# -------------------------------------------------------
*.bak
*.log
.temp*
.task/

# -------------------------------------------------------
# Repo-specific
# -------------------------------------------------------
.worktrees/
*.*key
*.pub
.config.env
/hugo/assets/jsconfig.json
/hugo/public/
/hugo/resources/
/hugo/.hugo_build.lock
/hugo/hugo_stats.json
*.iso
*.old
*.zip
.logs/
TODO.md
settings.local.json
*.profraw

# -------------------------------------------------------
# Retain (must be last — negations override above)
# -------------------------------------------------------
!.gitkeep
!.gitignore
!.env.example
!.env.sample
