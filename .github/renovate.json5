{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigestsToSemver",
    ":automergePr", // ":automergeBranch",
    ":automergeDigest",
    ":configMigration",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":docker",
    ":enablePreCommit",
    // ":rebaseStalePrs",
    ":renovatePrefix",
    ":semanticCommits",
    ":separateMultipleMajorReleases",
    ":separateMultipleMinorReleases",
    ":separatePatchReleases",
    ":timezone(America/New_York)",
    "github>ninerealmlabs/precommit-template//.github/renovate/autoMerge.json5",
    "github>ninerealmlabs/precommit-template//.github/renovate/customManagers.json5",
    "github>ninerealmlabs/precommit-template//.github/renovate/labels.json5",
    "github>ninerealmlabs/precommit-template//.github/renovate/packageRules.json5",
    "github>ninerealmlabs/precommit-template//.github/renovate/semanticCommits.json5",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  ignorePaths: ["/hugo/public/**", "/hugo/resources/**", "/hugo/themes/**"],
  packageRules: [
    // disable python
    {
      description: ["Ignore all Python dependencies"],
      matchManagers: ["pep621", "pip_requirements", "pip_setup", "pyenv", "setup-cfg"],
      enabled: false,
    },
    // Homebrew/actions has no semver releases and uses a branch (@master);
    // pinning its digest requires a cross-org GraphQL call that fails with App tokens
    {
      description: ["Skip digest pinning for Homebrew/actions"],
      matchDepNames: ["Homebrew/actions"],
      pinDigests: false,
    },
  ],
}
